{
  "name": "tt-api",
  "version": "1.0.0",
  "description": "API de tennis de table",
  "main": "app.ts",
  "scripts": {
    "start": "tsx src/app.ts",
    "db:seed": "tsx src/db/seed-run.ts",
    "openapi:generate-type": "npx openapi-typescript ./contracts/TT-api-contract.openapi.yaml -o ./src/types/api.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prettier": "npx prettier --write src/"
  },
  "type": "module",
  "author": "Benjamin FRANCHETEAU",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "^0.3.1",
    "fastify": "^5.8.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
